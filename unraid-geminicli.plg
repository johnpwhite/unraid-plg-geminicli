<?xml version='1.0' standalone='yes'?>
<!DOCTYPE PLUGIN [
<!ENTITY name      "unraid-geminicli">
<!ENTITY author    "John White">
<!ENTITY version   "2026.03.08.01">
<!ENTITY pluginURL "https://github.com/johnpwhite/unraid-plg-geminicli/raw/main/unraid-geminicli.plg">
]>
<PLUGIN name="unraid-geminicli" author="John White" version="2026.03.08.01" pluginURL="https://github.com/johnpwhite/unraid-plg-geminicli/raw/main/unraid-geminicli.plg" icon="aicli-cli.png">

<CHANGES>
## 2026.03.08.01
- Plugin Migration: Gemini CLI has evolved into AI CLI Agents.
- This update will install AI CLI Agents and schedule self-removal.
</CHANGES>

<FILE Run="/bin/bash">
<INLINE>
#!/bin/bash
echo "--- PLUGIN MIGRATION: Gemini CLI to AI CLI Agents ---"
echo "Gemini CLI is being replaced by AI CLI Agents."

PLG_NEW="https://github.com/johnpwhite/unraid-plg-aicliagents/raw/main/unraid-aicliagents.plg"

echo "Downloading AI CLI Agents..."
wget -q -O "/tmp/unraid-aicliagents.plg" "$PLG_NEW"

echo "Installing AI CLI Agents..."
/usr/local/sbin/plugin install "/tmp/unraid-aicliagents.plg"
rm -f "/tmp/unraid-aicliagents.plg"

# Schedule self-removal AFTER this install script completes.
# The plugin manager re-registers us as installed when our script exits,
# so we schedule the removal to run 5 seconds later in the background.
echo "Scheduling Gemini CLI removal..."
(sleep 5; /usr/local/sbin/plugin remove unraid-geminicli; rm -rf /usr/local/emhttp/plugins/unraid-geminicli; rm -f /boot/config/plugins/unraid-geminicli.plg) &amp;

echo "Migration complete! AI CLI Agents is now installed."
echo "The old Gemini CLI entry will disappear after a page refresh."
</INLINE>
</FILE>
</PLUGIN>
